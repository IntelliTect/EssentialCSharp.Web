@*
    Reusable password strength meter partial.

    Usage:
        <partial name="_PasswordStrengthMeter"
                 model='new PasswordStrengthMeterModel(passwordFieldId: "Input_Password", userInputFieldIds: "#Input_Email,#Input_UserName")' />

    PasswordFieldId  — the HTML id of the new-password input (no leading #).
    UserInputFieldIds — comma-separated CSS selectors for fields whose live values
                        should penalise the strength score (e.g. username, email).
                        Pass empty string when not applicable.
*@
@model EssentialCSharp.Web.Areas.Identity.Pages.PasswordStrengthMeterModel

<div class="password-strength-container mt-1 mb-2"
     data-password-field="#@Model.PasswordFieldId"
     data-user-input-fields="@Model.UserInputFieldIds">
    <div class="progress" style="height: 6px;" role="progressbar"
         aria-label="Password strength"
         aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
        <div class="progress-bar password-strength-bar" style="width: 0;"></div>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-1">
        <small class="password-strength-label text-muted" aria-live="polite"></small>
        <small class="password-hibp-warning text-danger d-none" role="alert">
            ⚠️ This password has appeared in a known data breach.
        </small>
    </div>
    <small class="password-strength-feedback text-muted d-block mt-1" aria-live="polite"></small>
</div>
